# Ignore everything by default; this repo is intended to publish only backend and frontend.
*

# Keep repository metadata and app source folders.
!/.gitignore
!/README.md
!/LICENSE
!/backend/
!/backend/**
!/frontend/
!/frontend/**

# Environment files
**/.env
**/.env.*
!**/.env.example
!**/.env.*.example

# Dependencies
**/node_modules/

# Build outputs
**/dist/
**/build/
**/coverage/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# OS / editor files
.DS_Store
.idea/
.vscode/

# Local tool config
.claude/
.codex/
